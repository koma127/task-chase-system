# =============================================
# LINE Messaging API
# =============================================
# LINEデベロッパーコンソールから取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# =============================================
# サーバー設定
# =============================================
# RailwayでデプロイしたときのURL（末尾スラッシュなし）
BASE_URL=https://your-app.railway.app

# ローカル開発時のポート番号（Railwayでは自動設定される）
PORT=5000

# =============================================
# 内部API認証キー
# =============================================
# deepdiveクライアントやダッシュボードからAPIを叩くときに使う
# ランダムな長い文字列を自分で決めて設定する
API_KEY=your_secret_api_key_here

# =============================================
# データベース
# =============================================
DATABASE_PATH=tasks.db

# =============================================
# レポート保存先ディレクトリ
# =============================================
REPORTS_DIR=reports

# =============================================
# Google Tasks API（任意）
# =============================================
# Google Cloud ConsoleでOAuth2認証情報を作成し、
# 以下のJSON文字列を1行で貼り付ける
# （token, refresh_token, client_id, client_secret を含む）
GOOGLE_TASKS_CREDENTIALS_JSON=

# Google Tasks のタスクリストID（@default で既定のリスト）
GOOGLE_TASKS_LIST_ID=@default
